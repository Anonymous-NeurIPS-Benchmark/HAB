      "contentUrl": "metadata/splits.json",
      "encodingFormat": "application/json",
      "sha256": "PLACEHOLDER"
    }
  ],
  "recordSet": [
    {
      "@type": "ml:RecordSet",
      "@id": "hab-instances",
      "name": "hab_instances",
      "description": "Core project instances for the HAB benchmark.",
      "field": [
        {
          "@type": "ml:Field",
          "@id": "hab-instances/project_id",
          "name": "project_id",
          "description": "Unique identifier for the project.",
          "dataType": "sc:Text",
          "source": {
            "fileObject": { "@id": "hab-instances-file" },
            "extract": { "jsonPath": "$.project_id" }
          }
        },
        {
          "@type": "ml:Field",
          "@id": "hab-instances/prompt",
          "name": "prompt",
          "description": "Natural language prompt describing the project.",
          "dataType": "sc:Text",
          "source": {
            "fileObject": { "@id": "hab-instances-file" },
            "extract": { "jsonPath": "$.prompt" }
          }
        },
        {
          "@type": "ml:Field",
          "@id": "hab-instances/target_board",
          "name": "target_board",
          "description": "The specific Arduino board family targeted.",
          "dataType": "sc:Text",
          "source": {
            "fileObject": { "@id": "hab-instances-file" },
            "extract": { "jsonPath": "$.target_board" }
          }
        },
        {
          "@type": "ml:Field",
          "@id": "hab-instances/difficulty",
          "name": "difficulty",
          "description": "The complexity level of the project (Low, Medium, High).",
          "dataType": "sc:Text",
          "source": {
            "fileObject": { "@id": "hab-instances-file" },
            "extract": { "jsonPath": "$.difficulty" }
          }
        },
        {
          "@type": "ml:Field",
          "@id": "hab-instances/components",
          "name": "components",
          "description": "List of hardware components required.",
          "dataType": "sc:Text",
          "source": {
            "fileObject": { "@id": "hab-instances-file" },
            "extract": { "jsonPath": "$.components" }
          }
        },
        {
          "@type": "ml:Field",
          "@id": "hab-instances/required_libraries",
          "name": "required_libraries",
          "description": "Arduino libraries required for compilation.",
          "dataType": "sc:Text",
          "source": {
            "fileObject": { "@id": "hab-instances-file" },
            "extract": { "jsonPath": "$.required_libraries" }
          }
        },
        {
          "@type": "ml:Field",
          "@id": "hab-instances/source_url",
          "name": "source_url",
          "description": "URL to the original project source.",
          "dataType": "sc:URL",
          "source": {
            "fileObject": { "@id": "hab-instances-file" },
            "extract": { "jsonPath": "$.source_url" }
          }
        },
        {
          "@type": "ml:Field",
          "@id": "hab-instances/redistribution_status",
          "name": "redistribution_status",
          "description": "Licensing status for redistribution.",
          "dataType": "sc:Text",
          "source": {
            "fileObject": { "@id": "hab-instances-file" },
            "extract": { "jsonPath": "$.redistribution_status" }
