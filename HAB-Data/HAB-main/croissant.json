  "@type": "sc:Dataset",
  "name": "HAB: Hardware-Grounded Arduino Benchmark",
  "description": "A comprehensive benchmark for evaluating LLMs on their ability to generate Arduino code grounded in physical hardware constraints.",
  "url": "ANONYMIZED_URL",
  "license": "ANONYMIZED_LICENSE_URL",
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "hab-instances-file",
      "name": "hab_instances.jsonl",
      "contentUrl": "metadata/hab_instances.jsonl",
      "encodingFormat": "application/jsonl",
      "sha256": "PLACEHOLDER"
    },
    {
      "@type": "cr:FileObject",
      "@id": "hardware-dictionary-file",
      "name": "hardware_dictionary.jsonl",
      "contentUrl": "hardware_dictionary/hardware_dictionary.jsonl",
      "encodingFormat": "application/jsonl",
      "sha256": "PLACEHOLDER"
    },
    {
      "@type": "cr:FileObject",
      "@id": "api-signatures-file",
      "name": "api_signatures.jsonl",
      "contentUrl": "hardware_dictionary/api_signatures.jsonl",
      "encodingFormat": "application/jsonl",
      "sha256": "PLACEHOLDER"
    },
    {
      "@type": "cr:FileObject",
      "@id": "prompts-file",
      "name": "prompts.jsonl",
      "contentUrl": "prompts/prompts.jsonl",
      "encodingFormat": "application/jsonl",
      "sha256": "PLACEHOLDER"
    },
    {
      "@type": "cr:FileObject",
      "@id": "splits-file",
